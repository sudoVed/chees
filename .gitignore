# =====================================================================
#  What to keep OUT of git. The deployable site is frontend/ — everything
#  it needs (engine-wasm.js, models/net.nnue, book/Book.bin) is committed.
#  This file excludes build output, large training artifacts, and junk.
# =====================================================================

# ---- WASM build output (regenerated by build.sh; the embedded copy in
#      frontend/js/engine-wasm.js is what ships) ----
/dist/
*.wasm.tmp*
*.o
*.obj

# ---- native tool binaries (rebuild from the .cpp via tools/build_*.{sh,ps1}) ----
/tools/tournament
/tools/checknet
/tools/*.exe
/tools/*.pdb
/tools/*.ilk
/tools/*.exp
/tools/*.lib

# ---- training data & model checkpoints: large and/or regenerable, never in git.
#      (the shipped net is frontend/models/net.nnue, which IS committed) ----
/training/data/
/training/train.bin
/training/train.bin.meta
/training/checkpoints/
*.pt
*.parquet

# ---- Python ----
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# ---- Node ----
node_modules/
npm-debug.log*
yarn-error.log*

# ---- OS / editor junk ----
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*~

# ---- logs ----
*.log

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
